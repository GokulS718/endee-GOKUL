# ──────────────────────────────────────────────────────────────────
# AI Fake News & Web Safety Detector — Environment Variables
# Copy this file to ".env" and fill in your actual API keys.
# ──────────────────────────────────────────────────────────────────

# 1. Google Gemini LLM (get at https://aistudio.google.com/app/apikey)
GOOGLE_API_KEY=your_gemini_api_key_here

# 2. Tavily Search API (get at https://tavily.com)
TAVILY_API_KEY=your_tavily_api_key_here

# 3. Google Safe Browsing (get at https://developers.google.com/safe-browsing/v4/get-started)
GOOGLE_SAFE_BROWSING_API_KEY=your_safe_browsing_api_key_here

# 4. Endee Vector DB API Key (Cloud Integration)
ENDEE_API_KEY=your_endee_api_key_here
