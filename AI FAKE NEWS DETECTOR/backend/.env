# 1. Google Gemini LLM (get at https://aistudio.google.com/app/apikey)
GOOGLE_API_KEY=AIzaSyCB1weughhUH2fZ7u7VtB_q9cekW-yEZsY

# 2. Tavily Search API (get at https://tavily.com)
#    Leave blank to fall back to free DuckDuckGo search.
TAVILY_API_KEY=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

# 3. Google Safe Browsing (get at https://developers.google.com/safe-browsing/v4/get-started)
#    Leave blank to use heuristic URL checks instead.
GOOGLE_SAFE_BROWSING_API_KEY=

# 4. Endee Vector DB — Local Docker server (no API key needed for local dev)
#    Run: docker run -p 8080:8080 -v ./endee-data:/data --name endee-server endeeio/endee-server:latest
ENDEE_URL=http://localhost:8080/api/v1

# 5. SQLite database (auto-created, no config needed)
DATABASE_URL=sqlite:///./fakenews.db
